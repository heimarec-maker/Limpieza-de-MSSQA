# Configuración de base de datos Oracle (Thin Mode)
DB_USER=USUARIO_DB
DB_PASSWORD=CONTRASEÑA_DB
DB_CONNECTION_STRING=host:puerto/SID_o_SERVICE_NAME

# Puerto del servidor API
PORT=3001

# SMW SOAP Endpoints
SMW_GEOREF_URL=http://.../WSGeorreferenciarCRService/
SMW_RFS_URL=http://.../WsRfsDireccionesService/
SMW_LIBERAR_URL=http://.../WsM6LiberarRecursosService/

# -------------------------------
# MongoDB (used for authentication users)
# If you use a single MONGO_URI you can ignore the individual vars and set MONGO_URI instead
MONGO_USER=mongo_user
MONGO_PASS=mongo_password
MONGO_HOST=localhost
MONGO_DB=mi_base
MONGO_AUTH_DB=admin
# Optional single URI (comment the above if you use this)
# MONGO_URI=mongodb://user:pass@host:27017/dbname?authSource=admin

# -------------------------------
# LDAP configuration (used for authentication)
# Use ldaps:// for secure LDAP (LDAPS) or ldap:// with StartTLS if supported
LDAP_URL=ldaps://ldap.example.com:636
LDAP_USER_SEARCH_BASE=ou=users,dc=ejemplo,dc=com
LDAP_ADMIN_DN=cn=bind_user,dc=ejemplo,dc=com
LDAP_ADMIN_PASSWORD=bind_user_password
# Attribute to use when username is provided (usually 'uid' or 'cn').
# The code will also accept an email (containing '@') and search by 'mail'.
LDAP_USERNAME_ATTRIBUTE=uid
# Optional timeout for LDAP operations (ms)
LDAP_BIND_TIMEOUT_MS=5000

# -------------------------------
# Session and auth
SESSION_SECRET=change_this_secret
# Enable temporary auth debug (console output) - should be false in production
AUTH_DEBUG=false
